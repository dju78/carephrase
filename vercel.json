{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/caretalk-training.html",
      "destination": "/carephrase-training.html",
      "permanent": true
    }
  ]
}