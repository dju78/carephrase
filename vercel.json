{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/health", "schedule": "0 8 * * *" }
  ],
  "redirects": [
    {
      "source": "/caretalk-training.html",
      "destination": "/care-note-training.html",
      "permanent": true
    },
    {
      "source": "/carephrase-training.html",
      "destination": "/care-note-training.html",
      "permanent": true
    }
  ]
}